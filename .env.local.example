# Supabase — from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — from your Stripe dashboard > Developers > API keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public base URL of the deployed site (used for Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated emails allowed to see /admin (the reviewer screen)
ADMIN_EMAILS=you@example.com

# Resend — from resend.com, for transactional emails (new request + delivered review notifications)
RESEND_API_KEY=
EMAIL_FROM=Second Opinion <notifications@yourdomain.com>
